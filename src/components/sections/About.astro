---
import ImagesTrip from "../images-trip"
import type { Translations } from "../../i18n";

interface Props {
    t: Translations["about"];
}

const { t } = Astro.props;

const photos = [
    {
        url: "/trip_1.jpg",
        alt: "Me looking Guayaquil backwards",
        transform: "-rotate-4"
    },
    {
        url: "/trip_3.jpg",
        alt: "Me posing with skyline background",
        transform: "rotate-4"
    },
    {
        url: "/trip_2.jpg",
        alt: "Me in front of a tower",
        transform: "-rotate-4"
    },
]
---

<style>
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
</style>

<section id="about" class="w-full max-w-[750px] px-5 py-10 mx-auto flex flex-col gap-8 block-dashed-no-top">
    <h2 class="text-2xl dark:text-white">
        {t.title}
    </h2>
    <p class="text-2xl dark:text-white" set:html={t.intro} />
    <div class="flex justify-between flex-col gap-5">
        <ul class="sm:hidden photos-scroll flex flex-row gap-10 justify-start overflow-x-scroll w-full p-4 scrollbar-hide">
            {photos.map((photo) => (
                <li class="shrink-0">
                    <img
                      src={photo.url}
                      alt={photo.alt}
                      width="200"
                      height="200"
                      loading="lazy"
                      class={`aspect-square border-8 border-primary rounded-[30px] overflow-hidden dark:border-white object-cover w-[200px] h-[200px] shadow-lg z-10 ${photo.transform}`}
                    />
                </li>
            ))}
        </ul>
        <ImagesTrip client:load />
        </div>
        <p class="italic -mt-8 text-secondary text-sm text-center sm:text-end">{t.photosCaption}</p>
    </div>
    <p class="text-secondary" set:html={t.body} />
</section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const photosScroll = document.querySelector('.photos-scroll');
        if (photosScroll) {
            photosScroll.scrollLeft = 0;
        }
    });
</script>
